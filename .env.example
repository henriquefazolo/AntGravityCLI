# Gemini API Key configuration
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model to be used by the CLI (e.g., gemini-2.5-flash, gemini-2.5-pro, gemini-3.1-flash-lite, etc.)
GEMINI_MODEL=gemini-3.1-flash-lite

# Default output language for CLI messages (e.g., en-us, pt-br)
ANTGRAVITY_LANG=en-us

# Run in YOLO mode by default (bypass safety confirmations)
# Set to 'true', '1', or 'yes' to enable. Leave empty or set to 'false' to disable.
ANTGRAVITY_YOLO=false

# Default workspace directories to restrict file tools (multiple values split by space)
# Example: ANTGRAVITY_WORKSPACE=C:\workspace1 C:\workspace2
# Note: Click splits multiple values using spaces, so avoid folder paths that contain spaces.
# ANTGRAVITY_WORKSPACE=

# Default system instructions text or path to a text file with instructions
# ANTGRAVITY_SYSTEM_INSTRUCTION=You are a helpful coding assistant.

# Default custom skills folder paths (multiple values split by space)
# Note: Click splits multiple values using spaces, so avoid folder paths that contain spaces.
# ANTGRAVITY_SKILLS_PATH=C:\custom_skills C:\shared_skills

# Hide agent thoughts and tool executions in the terminal by default
# Set to 'true', '1', or 'yes' to enable.
ANTGRAVITY_SILENT=false

# Display the agent's internal reasoning (chain of thought) in the console by default
# Set to 'true', '1', or 'yes' to enable.
ANTGRAVITY_VERBOSE=false
