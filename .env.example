# Gemini API Key configuration
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model to be used by the CLI (e.g., gemini-2.5-flash, gemini-2.5-pro, gemini-3.1-flash-lite, etc.)
GEMINI_MODEL=gemini-3.1-flash-lite

# Default output language for CLI messages (e.g., en-us, pt-br)
ANTGRAVITY_LANG=en-us

# Run in YOLO mode by default (bypass safety confirmations)
# Set to 'true', '1', or 'yes' to enable. Leave empty or set to 'false' to disable.
ANTGRAVITY_YOLO=false
